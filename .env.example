# Enlighten AI / DrK_Chat — environment template.
# Copy to .env and adjust:  cp .env.example .env
# Every value here is also the built-in default in config.py, so .env is optional.

# --- LLM: vLLM endpoint (OpenAI-compatible) serving the chat model ---
VLLM_BASE_URL=http://localhost:50033/v1
VLLM_API_KEY=dummy-key            # set to your vLLM --api-key (not a real secret here)
VLLM_MODEL=google/gemma-4-E4B-it
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# --- Embeddings (sentence-transformers, runs on GPU) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DEVICE=cuda:0

# --- WhisperX transcription fallback ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en
WHISPER_DEVICE_INDEX=0

# --- Chunking / hybrid retrieval ---
CHUNK_TARGET_TOKENS=450
CHUNK_OVERLAP_TOKENS=60
RETRIEVE_K=6                       # chunks sent to the LLM
RETRIEVE_POOL=30                   # candidates per retriever before RRF fusion
RRF_K=60                           # Reciprocal Rank Fusion constant
CLEAN_TRANSCRIPTS=1                # deterministic transcript cleaning at ingest (validated)

# --- Optional cross-encoder reranker (off by default; see rerank_experiment.md) ---
RERANK_ENABLED=0
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_POOL=50

# --- Guardrails (safety + prompt-injection) ---
GUARD_ENABLED=1
GUARD_LLM_CLASSIFIER=1             # LLM safety classifier (adds recall vs obfuscation)
GUARD_MAX_INPUT_CHARS=8000         # DoS / cost cap per message
